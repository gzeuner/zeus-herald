# Telegram Bot API (https://core.telegram.org/bots)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
# Optional: set to false/0 to force-disable even if credentials are present
# TELEGRAM_ENABLED=true

# ntfy topic URL (e.g. https://ntfy.sh/your-topic or self-hosted)
NTFY_URL=
# Optional bearer token for private/self-hosted ntfy
# NTFY_TOKEN=
# NTFY_ENABLED=true

# Shared notifier HTTP timeout (ms)
# NOTIFIER_TIMEOUT_MS=30000

# Runtime hardening
# QUEUE_MAX_SIZE=100
# QUEUE_DROP_POLICY=drop_oldest
# HEARTBEAT_MS=60000
# SHUTDOWN_TIMEOUT_MS=15000
# HEALTH_FILE=state/health.json
# DECISION_LOG=0
# DECISION_LOG_FILE=logs/decisions.ndjson

# --- Ingest (package 05, ADR-005) ---
# CAMERA_TYPE=reolink
# CAMERA_ID=front
# INGEST_MODE=files_only
# INGEST_MODE=direct_notify
# INGEST_TARGET_DIR=images/received
# INGEST_INTERVAL_MS=5000
# INGEST_TIMEOUT_MS=15000
# INGEST_WRITE_METADATA=true
# INGEST_ONCE=0

# Reolink: either full snapshot URL or host + credentials
# REOLINK_SNAPSHOT_URL=
# REOLINK_HOST=
# REOLINK_USER=
# REOLINK_PASSWORD=
# REOLINK_CHANNEL=0

# UpCam (optional): full URL or host + basic auth
# UPCAM_SNAPSHOT_URL=
# UPCAM_HOST=
# UPCAM_USER=
# UPCAM_PASSWORD=
