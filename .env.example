# Telegram Bot API (https://core.telegram.org/bots)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
# Optional: set to false/0 to force-disable even if credentials are present
# TELEGRAM_ENABLED=true

# ntfy topic URL (e.g. https://ntfy.sh/your-topic or self-hosted)
NTFY_URL=
# Optional bearer token for private/self-hosted ntfy
# NTFY_TOKEN=
# NTFY_ENABLED=true

# Shared notifier HTTP timeout (ms)
# NOTIFIER_TIMEOUT_MS=30000

# Runtime hardening
# QUEUE_MAX_SIZE=100
# QUEUE_DROP_POLICY=drop_oldest
# HEARTBEAT_MS=60000
# SHUTDOWN_TIMEOUT_MS=15000
# HEALTH_FILE=state/health.json
# DECISION_LOG=0
# DECISION_LOG_FILE=logs/decisions.ndjson
